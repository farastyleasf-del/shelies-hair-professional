# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000   # en producción: URL del contenedor frontend

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@host:PORT/db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT: usar un secreto largo y aleatorio en producción (openssl rand -hex 32)
JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES=8h
# Contraseña compartida para el login de estilistas y agentes
ADMIN_DEFAULT_PASSWORD=cambia-esto-en-produccion
SHARED_EMPLOYEE_PASSWORD=cambia-esto-en-produccion

# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
# Obtener en: Meta Business Manager → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token que definiste en Meta al registrar el webhook
WHATSAPP_VERIFY_TOKEN=
